K-ECT = {
  environment: environment-map
  ? key-list: [ + typed-crypto-key ]
  ? authority: [ + $crypto-key-type-choice ]
  ? key-type: key-type
  ? profile: $profile-type-choice
}

typed-crypto-key = {
  key: $crypto-key-type-choice
  ? key-type: uint .bits key-type
}

key-type = &(
  attest-key: 0
  identity-key: 1
)
